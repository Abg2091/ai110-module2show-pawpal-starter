classDiagram
    %% ── Enumerations ──────────────────────────────────────────────────────────

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }
    note for Priority "Ordered LOW < MEDIUM < HIGH — used for sorting"

    class TaskCategory {
        <<enumeration>>
        WALK
        FEEDING
        MEDICATION
        GROOMING
        ENRICHMENT
        OTHER
    }
    note for TaskCategory "MEDICATION and FEEDING are mandatory — the scheduler's\ntime filter never drops them, regardless of remaining budget"

    %% ── Core domain classes ───────────────────────────────────────────────────

    class Owner {
        +str name
        +int available_minutes
        +str preferences
        +Pet pet
        +list~Task~ tasks
        +add_task(task: Task) None
        +remove_task(task: Task) None
        +get_tasks() list
    }
    note for Owner "Holds exactly one Pet at a time by design. A multi-pet\nhousehold is modeled by the caller reassigning owner.pet and\nresetting owner.tasks per pet in a loop (see main.py / app.py),\nnot by the class itself."

    class Pet {
        +str name
        +str species
        +str breed
        +int age_years
        +list~Task~ tasks
        +add_task(task: Task) None
    }
    note for Pet "tasks is a secondary bookkeeping list some callers\n(e.g. main.py's cross-pet demo) populate for their own filtering.\nScheduler always sources tasks from Owner.get_tasks(), never from\nPet.tasks, so this list is not part of the scheduling pipeline."

    class Task {
        +str title
        +int duration_minutes
        +Priority priority
        +TaskCategory category
        +bool is_recurring
        +str frequency
        +bool completed
        +str last_scheduled_date
        +str id
        +is_high_priority() bool
        +mark_complete() None
        +next_occurrence(reference_date: str) Task
        +to_dict() dict
    }
    note for Task "last_scheduled_date holds the 'YYYY-MM-DD' date this\noccurrence is due for; next_occurrence() computes the following\none via timedelta based on frequency (daily = +1 day, weekly = +7)"

    %% ── Scheduling classes ────────────────────────────────────────────────────

    class Scheduler {
        +Owner owner
        +Pet pet
        +str start_time
        +str plan_date
        +generate_plan() DailyPlan
        -_carry_forward_tasks() None
        -_sort_by_priority(tasks: list) list
        -_filter_by_time(tasks: list, budget: int) list
        -_resolve_conflicts(entries: list) list
        -_explain(task: Task, slot: str) str
        +detect_conflicts(plans: list) list$
    }
    note for Scheduler "detect_conflicts() is static -- it compares entries\nacross a list of DailyPlans (possibly from different pets/owners),\nindependent of any one Scheduler instance's own owner/pet. Known\nlimitation: it compares clock times only, not plan.date, so plans\nfor different dates with matching times can be falsely flagged."

    class DailyPlan {
        +Pet pet
        +str date
        +list~ScheduledEntry~ entries
        +int total_duration_minutes
        +add_entry(entry: ScheduledEntry) None
        +get_summary() str
        +to_table() list
    }

    class ScheduledEntry {
        +Task task
        +str start_time
        +str end_time
        +str reason
        +duration_minutes() int
    }

    %% ── Relationships ─────────────────────────────────────────────────────────

    Owner "1" --> "1" Pet           : owns
    Owner "1" --> "0..*" Task       : manages
    Pet "1" --> "0..*" Task         : tracks

    Task --> Priority               : has
    Task --> TaskCategory           : categorized as

    Scheduler --> Owner             : uses
    Scheduler --> Pet               : schedules for
    Scheduler ..> DailyPlan        : creates

    DailyPlan "1" --> "0..*" ScheduledEntry : contains
    ScheduledEntry --> Task         : references
